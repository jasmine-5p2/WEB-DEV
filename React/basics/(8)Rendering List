# Complete Example

```jsx
function App() {

    const products = [

        { id: 1, name: "Laptop", price: 50000 },

        { id: 2, name: "Phone", price: 25000 },

        { id: 3, name: "Tablet", price: 18000 }

    ];

    return (

        <>
            {
                products.map((product) => (

                    <div key={product.id}>

                        <h2>{product.name}</h2>

                        <p>₹ {product.price}</p>

                    </div>

                ))
            }
        </>

    );

}

export default App;
```

